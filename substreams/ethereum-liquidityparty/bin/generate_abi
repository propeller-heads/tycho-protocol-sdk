#!/bin/bash

LMSR_HOME=../../../lmsr-amm
CHAIN_ID=1


abi() {
    jq '.abi' $LMSR_HOME/deployment/$CHAIN_ID/v1/out/$1.sol/$1.json > abi/$2.abi.json
    echo abi/$2.abi.json
}

# Copy ABI's to json files under abi/
abi PartyPlanner party_planner
abi PartyPool party_pool
abi PartyInfo party_info

cargo +nightly fmt
